  "description": "Increment memory-backed values using a task-graph style decomposition.",
  "interfaces": {
    "top_function": "task_graph_memory_increment_kernel",
    "arguments": [
      {
        "name": "input",
        "type": "const ap_uint<32> *",
        "direction": "input",
        "interface": "m_axi",
        "bundle": "gmem0"
      },
      {
        "name": "output",
        "type": "ap_uint<32> *",
        "direction": "output",
        "interface": "m_axi",
        "bundle": "gmem1"
      },
      {
        "name": "length",
        "type": "int",
        "direction": "input",
        "interface": "s_axilite"
      }
    ],
    "control": "s_axilite"
  },
  "behavior": [
    "Read each input element, increment it by one inside a task actor, and store the result to output memory.",
    "Keep task boundaries and channel ownership visible in comments.",
    "Preserve a channel depth of 16 between load, compute, and store stages."
  ],
  "clock": {
    "period_ns": 8.0,
    "uncertainty_ns": 0.8
  },
  "reset": {
    "strategy": "tool_default"
  },
  "constraints": [
    "Use hls_task metadata only when restart and ownership semantics are explicit.",
    "For current factual validation, prefer memory-backed task graphs over top-level AXI-Stream task graphs.",
    "Avoid global-state coupling inside the task graph."
  ],
