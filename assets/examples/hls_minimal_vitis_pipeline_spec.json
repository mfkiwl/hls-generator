{
  "name": "minimal_vitis_pipeline",
  "target": "hls",
  "design_requirements": {
    "target": "hls",
    "pipeline_required": true,
    "streamability": "streamable",
    "interface_family": "axi4",
    "interface_profile": {
      "axi4_variant": "axi4_full",
      "role": "master",
      "read_write_mode": "read_write",
      "data_width": 32,
      "addr_width": 32,
      "id_width": 1,
      "burst_support": false,
      "clock_reset_domain": {
        "clock": "ap_clk",
        "reset": "ap_rst_n"
      }
    },
    "confirmed_by_user": true,
    "confirmation_notes": "Use a minimal Vitis kernel flow with a clean compile/link boundary and stable bundle naming."
  },
  "streamability": "streamable",
  "interface_family": "axi4",
  "interface_profile": {
    "axi4_variant": "axi4_full",
    "role": "master",
    "read_write_mode": "read_write",
    "data_width": 32,
    "addr_width": 32,
    "id_width": 1,
    "burst_support": false,
    "clock_reset_domain": {
      "clock": "ap_clk",
      "reset": "ap_rst_n"
    }
  },
  "pipeline_required": true,
  "codegen_plan_required": true,
  "description": "Scale a memory-backed vector using a minimal Vitis kernel structure with a clear compile/link split.",
  "interfaces": {
    "top_function": "minimal_vitis_pipeline_kernel",
    "arguments": [
      {
        "name": "input",
        "type": "const ap_uint<32> *",
        "direction": "input",
        "interface": "m_axi",
        "bundle": "gmem0",
        "depth": 1024
      },
      {
        "name": "output",
        "type": "ap_uint<32> *",
        "direction": "output",
        "interface": "m_axi",
        "bundle": "gmem1",
        "depth": 1024
      },
      {
        "name": "scale",
        "type": "ap_uint<16>",
        "direction": "input",
        "interface": "s_axilite"
      },
      {
        "name": "length",
        "type": "int",
        "direction": "input",
        "interface": "s_axilite"
      }
    ],
    "control": "s_axilite"
  },
  "behavior": [
    "For each index below length, output[index] equals input[index] multiplied by scale.",
    "Keep the generated HLS source focused on kernel behavior rather than host or package-stage orchestration.",
    "Use stable bundle naming and explicit depth values so downstream compile and link steps stay reviewable."
  ],
  "clock": {
    "period_ns": 10.0,
    "uncertainty_ns": 1.0
  },
  "reset": {
    "strategy": "tool_default"
  },
  "constraints": [
    "Use Vitis HLS compatible C++.",
    "Preserve a clean compile/link boundary in the project description, not by generating package or host files."
  ],
  "outputs": [
    {
      "path": "src/minimal_vitis_pipeline_kernel.h",
      "kind": "header",
      "language": "cpp"
    },
    {
      "path": "src/minimal_vitis_pipeline_kernel.cpp",
      "kind": "source",
      "language": "cpp"
    },
    {
      "path": "tb/minimal_vitis_pipeline_kernel_tb.cpp",
      "kind": "testbench",
      "language": "cpp"
    },
    {
      "path": "hls_config.cfg",
      "kind": "config",
      "language": "ini"
    }
  ],
  "notes": [
    "The surrounding Vitis compile/link flow is background engineering context and is not emitted as output."
  ],
  "subfunctions": [],
  "workflow": {
    "board_acceptance": {
      "profile": "u55c_m_axi_host",
      "host_template": "vector_scale_host"
    }
  },
  "performance": {
    "target_ii": 1,
    "max_length": 1024
  },
  "hls_profile": {
    "example_pattern": "minimal_vitis_pipeline",
    "allowed_libraries": [
      "ap_int.h"
    ],
    "required_headers": [
      "ap_int.h"
    ],
    "required_pragmas": [
      "#pragma HLS INTERFACE m_axi port=input bundle=gmem0",
      "#pragma HLS INTERFACE m_axi port=output bundle=gmem1",
      "#pragma HLS PIPELINE II=1"
    ],
    "required_metadata_fields": [
      "compile_link_boundary",
      "top_kernel_role",
      "bundle_naming_rule"
    ],
    "metadata": {
      "compile_link_boundary": "Kernel source and cfg support v++ compile/link stages without mixing package logic into the HLS code.",
      "top_kernel_role": "The top kernel source owns the interface contract and main compute loop.",
      "bundle_naming_rule": "Use stable gmem-style bundle names so downstream link planning stays readable."
    },
    "forbidden_combinations": [],
    "required_cfg_entries": [
      "clock=10.0"
    ]
  }
}
