    "arguments": [
      {"name": "input", "type": "const ap_fixed<16,8, AP_RND, AP_SAT> *", "direction": "input", "interface": "m_axi", "bundle": "gmem0", "depth": 1024},
      {"name": "output", "type": "ap_fixed<16,8, AP_RND, AP_SAT> *", "direction": "output", "interface": "m_axi", "bundle": "gmem1", "depth": 1024},
