    "pipeline_required": true,
    "streamability": "streamable",
    "interface_family": "axi_stream",
    "interface_profile": {
      "keep_ready": true,
      "keep_last": false,
      "data_width": 32,
      "clock_reset_domain": {
        "clock": "ap_clk",
        "reset": "ap_rst_n"
      }
    },
    "confirmed_by_user": true,
    "confirmation_notes": "Use AXI-Stream style HLS arguments and preserve one output token per input token."
