  "streamability": "streamable",
  "interface_family": "axi_stream",
  "interface_profile": {
    "keep_ready": true,
    "keep_last": false,
    "data_width": 32,
    "clock_reset_domain": {
      "clock": "ap_clk",
      "reset": "ap_rst_n"
    }
  },
  "pipeline_required": true,
  "codegen_plan_required": true,
  "description": "Read 32-bit tokens from an HLS stream, increment each token, and write the result stream.",
  "interfaces": {
    "top_function": "axis_increment_kernel",
    "arguments": [
      {
        "name": "in_stream",
        "type": "hls::stream<ap_uint<32> >&",
        "direction": "input",
        "interface": "axis"
      },
      {
        "name": "out_stream",
        "type": "hls::stream<ap_uint<32> >&",
        "direction": "output",
        "interface": "axis"
      },
      {
        "name": "length",
        "type": "int",
        "direction": "input",
        "interface": "s_axilite"
      }
    ],
    "control": "s_axilite"
  },
  "behavior": [
    "For each of length input tokens, emit exactly one output token with value + 1.",
    "Use a pipelined loop with II=1 unless stream availability prevents it.",
    "Do not use handwritten HDL; keep the implementation in Vitis HLS C++."
  ],
  "clock": {
    "period_ns": 8.0,
    "uncertainty_ns": 0.8
  },
  "reset": {
    "strategy": "tool_default"
  },
  "constraints": [
    "Use hls::stream and ap_uint types.",
    "Avoid dynamic allocation, recursion, exceptions, and unsupported standard library features."
  ],
  "outputs": [
    {
      "path": "src/axis_increment_kernel.h",
      "kind": "header",
      "language": "cpp"
    },
    {
      "path": "src/axis_increment_kernel.cpp",
