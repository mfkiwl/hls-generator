  "hls_profile": {
    "example_pattern": "array_partition",
    "allowed_libraries": [
      "ap_int.h"
    ],
    "required_headers": [
      "ap_int.h"
    ],
    "required_pragmas": [
      "#pragma HLS PIPELINE II=1",
      "#pragma HLS ARRAY_PARTITION variable=local_buf complete dim=1"
    ],
    "required_metadata_fields": [
      "target_buffer",
      "partition_dim",
      "partition_type",
      "partition_factor",
      "contention_reason"
    ],
    "metadata": {
      "target_buffer": "local_buf",
      "partition_dim": 1,
      "partition_type": "complete",
      "partition_factor": 16,
      "contention_reason": "The pipelined outer loop requires parallel reads from the local tile buffer."
    },
    "forbidden_combinations": [
      {
        "all_of": [
          "#pragma HLS ARRAY_PARTITION variable=local_buf complete dim=1",
          "#pragma HLS ARRAY_RESHAPE variable=local_buf complete dim=1"
        ],
        "message": "Do not partition and reshape the same local buffer in the same solution."
      }
    ],
    "required_cfg_entries": [
      "clock=10.0"
    ]
