  "codegen_plan_required": true,
  "description": "Template for a kernel that uses ARRAY_PARTITION on a local buffer to relieve a confirmed bandwidth bottleneck.",
  "interfaces": {
    "top_function": "template_array_partition_kernel",
    "arguments": [
      {
        "name": "input",
        "type": "const ap_uint<32> *",
        "direction": "input",
        "interface": "m_axi",
        "bundle": "gmem0",
        "depth": 1024
      },
      {
        "name": "output",
        "type": "ap_uint<32> *",
        "direction": "output",
        "interface": "m_axi",
        "bundle": "gmem1",
        "depth": 1024
      },
      {
        "name": "scale",
        "type": "ap_uint<16>",
        "direction": "input",
        "interface": "s_axilite"
      },
      {
        "name": "length",
        "type": "int",
        "direction": "input",
        "interface": "s_axilite"
      }
    ],
    "control": "s_axilite"
  },
  "behavior": [
    "Replace these sample semantics with the confirmed partitioned-buffer behavior.",
    "Keep ARRAY_PARTITION tied to a real memory-port or parallel-read bottleneck."
  ],
  "clock": {
    "period_ns": 10.0,
    "uncertainty_ns": 1.0
  },
  "reset": {
    "strategy": "tool_default"
  },
  "constraints": [
    "Use a sequentially verifiable baseline before adding ARRAY_PARTITION.",
    "Do not combine ARRAY_PARTITION and ARRAY_RESHAPE on the same buffer."
  ],
