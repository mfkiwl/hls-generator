  "description": "Template for a fixed-point kernel with explicit numeric-contract metadata.",
  "interfaces": {
    "top_function": "template_fixed_point_kernel",
    "arguments": [
      {
        "name": "input",
        "type": "const ap_fixed<16,8, AP_RND, AP_SAT> *",
        "direction": "input",
        "interface": "m_axi",
        "bundle": "gmem0",
        "depth": 1024
      },
      {
        "name": "output",
        "type": "ap_fixed<16,8, AP_RND, AP_SAT> *",
        "direction": "output",
        "interface": "m_axi",
        "bundle": "gmem1",
        "depth": 1024
      },
      {
        "name": "scale",
        "type": "ap_fixed<16,4, AP_RND, AP_SAT>",
        "direction": "input",
        "interface": "s_axilite"
      },
      {
        "name": "length",
        "type": "int",
        "direction": "input",
        "interface": "s_axilite"
      }
    ],
    "control": "s_axilite"
  },
  "behavior": [
    "Replace these sample semantics with the confirmed fixed-point kernel behavior.",
    "Keep the numeric contract reviewable in comments and test vectors."
  ],
  "clock": {
    "period_ns": 10.0,
    "uncertainty_ns": 1.0
  },
  "reset": {
    "strategy": "tool_default"
  },
  "constraints": [
    "Preserve the confirmed quantization and overflow policy.",
    "Do not enable unsafe math unless the user explicitly confirms the approximation."
