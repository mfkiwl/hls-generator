{
  "version": 1,
  "paths": {
    "default_workflow_config": "integration/default_workflow_config.json",
    "workflow_state_file": "workflow-state.json",
    "examples_dir": "assets/examples",
    "smoke_root": "_smoke_runs",
    "generated_roots": [
      "_smoke_runs",
      "reports"
    ],
    "protected_roots": [
      "agents",
      "assets",
      "integration",
      "references",
      "runtime",
      "scripts",
      "smoke"
    ],
    "protected_files": [
      "DESIGN_GOALS.md",
      "SKILL.md"
    ]
  },
  "vitis": {
    "missing_tool_id": "vitis",
    "tools": [
      {
        "name": "vitis-run",
        "which": "vitis-run",
        "label": "vitis-run Tcl flow",
        "command": [
          "vitis-run",
          "--mode",
          "hls",
          "--tcl",
          "{tcl}"
        ]
      },
      {
        "name": "vitis_hls",
        "which": "vitis_hls",
        "label": "vitis_hls Tcl flow",
        "command": [
          "vitis_hls",
          "-f",
          "{tcl}"
        ]
      }
    ],
    "tcl": {
      "temp_tcl_prefix": ".hls_generator_",
      "project_dir_prefix": ".hls_generator_vitis_",
      "solution_name": "solution1"
    },
    "timeouts_s": {
      "compile": 180,
      "execute": 180,
      "implement": 600,
      "cosim": 900
    },
    "skill_routing": {
      "preferred_skill": "vitis-developer",
      "fallback_skills": [
        "vitis-hls-synthesis"
      ]
    }
  },
  "remote_validation": {
    "erie_skill_dir": "${home}/.codex/skills/erie-remote-ssh",
    "erie_settings_path": "${erie_skill_dir}/config/defaults.json",
    "local_run_root": "reports/remote-validation",
    "remote_tmp_dir": ".hls-generator-remote-validation",
    "default_timeout_s": 60,
    "python_env": {
      "PYTHONUTF8": "1",
      "PYTHONIOENCODING": "utf-8"
    },
    "link_probe_command": [
      "bash",
      "-lc",
      "printf 'HLS_REMOTE_LINK_OK\\n'; printf 'host='; hostname; printf '\\npwd='; pwd; printf '\\npython='; python3 --version 2>&1"
    ],
    "vitis_profiles": {}
  },
  "skill_dependencies": [
    {
      "id": "remote-ssh",
      "level": "required",
      "purpose": "Remote SSH server discovery, remote links, and remote Vitis HLS validation.",
      "scopes": [
        "core"
      ],
      "repo_url": "https://github.com/Eriemon/remote-ssh.git",
      "ref": "main",
      "paths": [
        "."
      ],
      "expected_skill_names": [
        "erie-remote-ssh"
      ],
      "destination_names": [
        "erie-remote-ssh"
      ],
      "aliases": [],
      "adapter": "erie-remote-ssh",
      "blocking": true,
      "required_files": [
        "scripts/remote_ssh.py",
        "config/defaults.json"
      ]
    },
    {
      "id": "fpga-hls-routing",
      "level": "required",
      "purpose": "Core Vitis HLS skill routing for generation, simulation, cosim, and HLS debug guidance.",
      "scopes": [
        "core"
      ],
      "repo_url": "https://github.com/adeleempurpled290/FPGA-Agent-skills.git",
      "ref": "main",
      "paths": [
        "vitis-hls-synthesis"
      ],
      "expected_skill_names": [
        "vitis-hls-synthesis"
      ],
      "destination_names": [
        "vitis-hls-synthesis"
      ],
      "aliases": [],
      "adapter": "fpga-agent-skills",
      "blocking": true,
      "alternative_providers": [
        {
          "for": "vitis-hls-synthesis",
          "skill_names": [
            "vitis-developer"
          ],
          "aliases": [],
          "install_policy": "skip_if_present",
          "purpose": "Use vitis-developer for Vitis HLS development, simulation, cosim, and debug guidance when it is already installed."
        }
      ]
    },
    {
      "id": "fpga-vivado-guidance",
      "level": "recommended",
      "purpose": "Optional Vivado analysis, constraints, simulation, implementation, debug, synthesis, and Tcl guidance for non-core HLS follow-on tasks.",
      "scopes": [
        "vivado-extended"
      ],
      "repo_url": "https://github.com/adeleempurpled290/FPGA-Agent-skills.git",
      "ref": "main",
      "paths": [
        "vivado-analysis",
        "vivado-constraints",
        "vivado-debug",
        "vivado-impl",
        "vivado-sim",
        "vivado-synth",
        "vivado-tcl"
      ],
      "expected_skill_names": [
        "vivado-analysis",
        "vivado-constraints",
        "vivado-debug",
        "vivado-impl",
        "vivado-sim",
        "vivado-synth",
        "vivado-tcl"
      ],
      "destination_names": [
        "vivado-analysis",
        "vivado-constraints",
        "vivado-debug",
        "vivado-impl",
        "vivado-sim",
        "vivado-synth",
        "vivado-tcl"
      ],
      "aliases": [],
      "adapter": "fpga-agent-skills",
      "blocking": true
    },
    {
      "id": "superpowers",
      "level": "recommended",
      "purpose": "Planning, task management, systematic debugging, TDD, and verification workflows.",
      "scopes": [
        "all"
      ],
      "repo_url": "https://github.com/obra/superpowers.git",
      "ref": "main",
      "paths": [
        "skills/using-superpowers",
        "skills/brainstorming",
        "skills/writing-plans",
        "skills/executing-plans",
        "skills/systematic-debugging",
        "skills/test-driven-development",
        "skills/verification-before-completion"
      ],
      "expected_skill_names": [
        "using-superpowers",
        "brainstorming",
        "writing-plans",
        "executing-plans",
        "systematic-debugging",
        "test-driven-development",
        "verification-before-completion"
      ],
      "destination_names": [
        "using-superpowers",
        "brainstorming",
        "writing-plans",
        "executing-plans",
        "systematic-debugging",
        "test-driven-development",
        "verification-before-completion"
      ],
      "aliases": [],
      "adapter": "superpowers",
      "blocking": true
    },
    {
      "id": "context-engineering",
      "level": "recommended",
      "purpose": "Context engineering guidance for agent-system debugging and engineering-task diagnosis.",
      "scopes": [
        "all"
      ],
      "repo_url": "https://github.com/muratcankoylan/Agent-Skills-for-Context-Engineering.git",
      "ref": "main",
      "paths": [
        "."
      ],
      "expected_skill_names": [
        "context-engineering"
      ],
      "destination_names": [
        "context-engineering"
      ],
      "aliases": [
        "context-engineering-collection"
      ],
      "adapter": "context-engineering",
      "blocking": true
    }
  ]
}
